# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.js text
*.jsx text
*.json text
*.css text
*.html text
*.md text
*.py text
*.txt text
*.yml text
*.yaml text

# Denote binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
*.xlsx binary
*.svg binary
